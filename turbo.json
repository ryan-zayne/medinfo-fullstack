{
	"$schema": "https://turborepo.org/schema.json",

	"tasks": {
		"dev": {
			"cache": false,
			"persistent": true
		},
		"build": {
			"dependsOn": ["^build"],
			"outputs": ["dist/**", ".next/**", "!.next/cache/**", "build", ".vercel", ".outputs/**"]
		},
		"build:nitro": {
			"outputs": [".vercel", ".outputs/**"]
		},
		"db:studio": {
			"cache": false,
			"persistent": true
		},
		"db:push": {
			"cache": false
		},
		"db:generate": {
			"cache": false
		},
		"db:migrate": {
			"cache": false
		},
		"db:seed": {
			"cache": false
		},
		"lint:format": {},
		"lint:eslint": {},
		"lint:type-check": {},
		"knip": {}
	}
}
