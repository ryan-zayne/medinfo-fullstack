{
	"$schema": "https://turborepo.org/schema.json",

	"tasks": {
		"dev": {
			"cache": false,
			"persistent": true
		},
		"build": {
			"dependsOn": ["^build"],
			"outputs": ["dist/**", ".next/**", "!.next/cache/**", "build", ".vercel"]
		},
		"db:studio": {
			"persistent": true
		},
		"db:push": {},
		"db:generate": {},
		"db:migrate": {},
		"lint:format": {},
		"lint:eslint": {},
		"lint:type-check": {},
		"knip": {}
	}
}
