{
	"name": "@medinfo/db",
	"type": "module",
	"private": true,
	"exports": {
		".": "./src/db.ts",
		"./schema/*": "./src/schema/*.ts"
	},
	"scripts": {
		"db:generate": "drizzle-kit generate",
		"db:migrate": "cross-env DB_MIGRATING=true drizzle-kit migrate",
		"db:push": "drizzle-kit push",
		"db:seed": "cross-env DB_SEEDING=true tsx src/seed.ts",
		"db:studio": "drizzle-kit studio",
		"dev": "tsx watch src/db.ts",
		"dev:docker": "docker compose up medinfo-postgres-db",
		"lint:eslint": "eslint . --max-warnings 0",
		"lint:format": "prettier --write .",
		"lint:type-check": "tsc --pretty -p tsconfig.json"
	},
	"dependencies": {
		"@dotenvx/dotenvx": "catalog:",
		"@faker-js/faker": "^10.2.0",
		"@medinfo/env": "workspace:*",
		"@node-rs/argon2": "^2.0.2",
		"@zayne-labs/tsconfig": "0.11.18",
		"consola": "3.4.2",
		"cross-env": "^10.1.0",
		"drizzle-kit": "0.31.8",
		"drizzle-orm": "0.45.1",
		"drizzle-zod": "0.8.3",
		"pg": "8.17.0",
		"tsx": "4.21.0",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@total-typescript/ts-reset": "0.6.1",
		"@types/pg": "8.16.0",
		"tsdown": "catalog:",
		"typescript": "catalog:"
	}
}
