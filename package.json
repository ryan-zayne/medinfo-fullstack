{
	"name": "@medinfo/root",
	"type": "module",
	"version": "0.0.0",
	"packageManager": "pnpm@10.33.0",
	"license": "MIT",
	"scripts": {
		"build": "turbo run build",
		"build:frontend": "turbo run --filter=@medinfo/frontend build",
		"build:transactional": "turbo run --filter=@medinfo/transactional build",
		"db:generate": "turbo run --filter=@medinfo/db db:generate",
		"db:migrate": "turbo run --filter=@medinfo/db db:migrate",
		"db:push": "turbo run --filter=@medinfo/db db:push",
		"db:seed": "turbo run --filter=@medinfo/db db:seed",
		"db:studio": "turbo run --filter=@medinfo/db db:studio",
		"dev:backend": "turbo run --filter=@medinfo/backend dev",
		"dev:frontend": "turbo run --filter=@medinfo/frontend dev",
		"inspect:eslint-config": "pnpx @eslint/config-inspector@latest",
		"lint:eslint": "turbo run lint:eslint",
		"lint:eslint:interactive": "pnpx eslint-interactive@latest . --max-warnings=0 --fix",
		"lint:eslint:root": "eslint . --max-warnings=0",
		"lint:format": "turbo run lint:format",
		"lint:format:root": "prettier --write .",
		"lint:type-check": "turbo run lint:type-check",
		"prepare": "husky || true"
	},
	"devDependencies": {
		"@eslint-react/eslint-plugin": "3.0.0",
		"@next/eslint-plugin-next": "16.2.1",
		"@tanstack/eslint-plugin-query": "5.95.2",
		"@types/node": "25.5.0",
		"@zayne-labs/eslint-config": "0.12.4",
		"@zayne-labs/prettier-config": "0.12.4",
		"eslint": "10.1.0",
		"eslint-plugin-better-tailwindcss": "4.3.2",
		"eslint-plugin-react-hooks": "7.0.1",
		"eslint-plugin-react-refresh": "0.5.2",
		"eslint-plugin-react-you-might-not-need-an-effect": "0.9.2",
		"husky": "9.1.7",
		"lint-staged": "16.4.0",
		"prettier": "3.8.1",
		"prettier-plugin-classnames": "0.10.1",
		"prettier-plugin-merge": "0.10.1",
		"prettier-plugin-tailwindcss": "0.7.2",
		"tailwindcss": "4.2.2",
		"turbo": "2.8.20",
		"typescript": "catalog:"
	}
}
