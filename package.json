{
	"name": "@medinfo/root",
	"type": "module",
	"version": "0.0.0",
	"packageManager": "pnpm@10.25.0",
	"license": "MIT",
	"scripts": {
		"build": "turbo run build",
		"db:generate": "turbo run --filter=@medinfo/backend-db db:generate",
		"db:migrate": "turbo run --filter=@medinfo/backend-db db:migrate",
		"db:push": "turbo run --filter=@medinfo/backend-db db:push",
		"db:seed": "turbo run --filter=@medinfo/backend-db db:seed",
		"db:studio": "turbo run --filter=@medinfo/backend-db db:studio",
		"dev:backend": "pnpm run --filter=@medinfo/backend dev",
		"dev:frontend": "turbo run --filter=@medinfo/frontend dev",
		"inspect:eslint-config": "pnpx @eslint/config-inspector@latest",
		"lint:eslint": "eslint . --max-warnings=0",
		"lint:eslint:interactive": "pnpx eslint-interactive@latest . --max-warnings=0 --fix",
		"lint:format": "turbo run lint:format",
		"lint:type-check": "turbo run lint:type-check",
		"prepare": "husky || true"
	},
	"devDependencies": {
		"@eslint-react/eslint-plugin": "2.3.13",
		"@next/eslint-plugin-next": "16.0.10",
		"@types/node": "25.0.2",
		"@zayne-labs/eslint-config": "0.11.5",
		"@zayne-labs/prettier-config": "0.11.5",
		"eslint": "9.39.2",
		"eslint-plugin-better-tailwindcss": "3.8.0",
		"eslint-plugin-react-hooks": "7.0.1",
		"eslint-plugin-react-refresh": "0.4.24",
		"eslint-plugin-react-you-might-not-need-an-effect": "0.7.0",
		"husky": "9.1.7",
		"lint-staged": "16.2.7",
		"prettier": "3.7.4",
		"tailwindcss": "4.1.18",
		"turbo": "2.6.3",
		"typescript": "catalog:"
	}
}
