{
	"name": "@medinfo/backend",
	"type": "module",
	"private": true,
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsdown",
		"compile": "bun build --compile --minify --sourcemap --bytecode ./src/server.ts --outfile server",
		"dev": "cross-env NODE_ENV=development tsx watch src/server.ts --clear-screen=false",
		"lint:eslint": "eslint . --max-warnings 0",
		"lint:format": "prettier --write .",
		"lint:type-check": "tsc --pretty -p tsconfig.json",
		"start": "cross-env NODE_ENV=production tsx src/server.ts",
		"start:built": "cross-env NODE_ENV=production node dist/server.js"
	},
	"dependencies": {
		"@colors/colors": "^1.6.0",
		"@dotenvx/dotenvx": "catalog:",
		"@hono-storage/node-disk": "^0.0.17",
		"@hono/node-server": "1.19.7",
		"@huggingface/transformers": "^3.8.1",
		"@medinfo/db": "workspace:*",
		"@medinfo/env": "workspace:*",
		"@medinfo/shared": "workspace:*",
		"@node-rs/argon2": "^2.0.2",
		"@zayne-labs/callapi": "1.11.39",
		"@zayne-labs/toolkit-core": "0.12.22",
		"@zayne-labs/toolkit-type-helpers": "0.12.22",
		"@zayne-labs/tsconfig": "^0.11.16",
		"arctic": "^3.7.0",
		"cloudinary": "^2.8.0",
		"consola": "3.4.2",
		"cross-env": "^10.1.0",
		"date-fns": "4.1.0",
		"drizzle-orm": "0.45.1",
		"hono": "4.11.3",
		"hono-pino": "^0.10.3",
		"hono-rate-limiter": "^0.5.3",
		"jsonwebtoken": "^9.0.3",
		"pino": "^10.1.0",
		"pino-pretty": "^13.1.3",
		"tsx": "4.21.0",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@total-typescript/ts-reset": "0.6.1",
		"@types/jsonwebtoken": "^9.0.10",
		"@types/node": "25.0.3",
		"tsdown": "catalog:",
		"typescript": "catalog:"
	}
}
