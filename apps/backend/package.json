{
	"name": "@medinfo/backend",
	"type": "module",
	"private": true,
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsdown",
		"build:nitro": "vite build",
		"compile": "bun build --compile --minify --sourcemap --bytecode ./src/server.ts --outfile server",
		"dev": "cross-env NODE_ENV=development pnpm dev:watch",
		"dev:docker-db": "docker compose up medinfo-postgres-db medinfo-redis-cache medinfo-redis-queue",
		"dev:nitro": "vite dev",
		"dev:prod": "cross-env NODE_ENV=production pnpm dev:watch",
		"dev:watch": "tsx watch src/server.ts --clear-screen=false",
		"lint:eslint": "eslint . --max-warnings 0",
		"lint:format": "prettier --write .",
		"lint:type-check": "tsc --pretty -p tsconfig.json",
		"preview:nitro": "vite preview",
		"start": "cross-env NODE_ENV=production tsx src/server.ts",
		"start:built": "cross-env NODE_ENV=production node dist/server.js",
		"start:dev": "cross-env NODE_ENV=development tsx src/server.ts"
	},
	"dependencies": {
		"@bull-board/api": "^7.0.0",
		"@bull-board/hono": "^7.0.0",
		"@colors/colors": "^1.6.0",
		"@dotenvx/dotenvx": "1.62.0",
		"@hono-storage/node-disk": "^0.0.17",
		"@hono/node-server": "2.0.0",
		"@huggingface/transformers": "^4.1.0",
		"@medinfo/db": "workspace:*",
		"@medinfo/env": "workspace:*",
		"@medinfo/shared": "workspace:*",
		"@medinfo/transactional": "workspace:*",
		"@node-rs/argon2": "^2.0.2",
		"@zayne-labs/callapi": "1.12.4",
		"@zayne-labs/toolkit-core": "0.12.49",
		"@zayne-labs/toolkit-type-helpers": "0.12.49",
		"@zayne-labs/tsconfig": "^0.13.4",
		"arctic": "^3.7.0",
		"bullmq": "^5.74.1",
		"cloudinary": "^2.9.0",
		"consola": "3.4.2",
		"cross-env": "^10.1.0",
		"date-fns": "4.1.0",
		"drizzle-orm": "0.45.2",
		"hono": "4.12.15",
		"hono-pino": "^0.10.3",
		"hono-rate-limiter": "^0.5.3",
		"ioredis": "^5.10.1",
		"jsonwebtoken": "^9.0.3",
		"nodemailer": "^8.0.5",
		"pino": "^10.3.1",
		"pino-pretty": "^13.1.3",
		"redis": "^5.12.1",
		"tsx": "4.21.0",
		"zod": "4.3.6"
	},
	"devDependencies": {
		"@total-typescript/ts-reset": "0.6.1",
		"@types/jsonwebtoken": "^9.0.10",
		"@types/node": "25.6.0",
		"@types/nodemailer": "^8.0.0",
		"nitro": "3.0.260415-beta",
		"tsdown": "0.21.10",
		"typescript": "6.0.3",
		"vite": "^8.0.8"
	}
}
