# ============================================
# MedInfo Backend Environment Configuration
# ============================================
# Copy this file to .env and fill in your actual values
# Never commit to version control

# ============================================
# Application Configuration
# ============================================
# Environment: development or production
NODE_ENV=development

# Server port (default: 8000)
PORT=8000

# Logging level: debug, info, warn, error, fatal, silent
LOG_LEVEL=info

# ============================================
# Database Configuration
# ============================================
# Development database connection
DATABASE_URL_DEV=postgresql://postgres:postgres@localhost:5432/medinfo

# Production database connection
DATABASE_URL_PROD=postgresql://username:password@your-host:5432/medinfo

# Database operation flags
DB_MIGRATING=false
DB_SEEDING=false

# Default password for seeded users (used only during development)
SEED_PASSWORD=password123

# ============================================
# JWT Authentication
# ============================================
# Generate strong secrets using: openssl rand -base64 32
ACCESS_SECRET=your-access-secret-here-min-32-chars
REFRESH_SECRET=your-refresh-secret-here-min-32-chars

# Token expiration times (milliseconds)
ACCESS_JWT_EXPIRES_IN=300000        # 5 minutes
REFRESH_JWT_EXPIRES_IN=900000       # 15 minutes

# ============================================
# Host Configuration
# ============================================
# Development URLs (usually defaults are fine)
BASE_BACKEND_HOST_DEV=http://localhost:8000
BASE_FRONTEND_HOST_DEV=http://localhost:3000

# Production URLs (replace with your actual domain)
BASE_BACKEND_HOST_PROD=https://api.yourdomain.com
BASE_FRONTEND_HOST_PROD=https://yourdomain.com

# ============================================
# Redis Configuration
# ============================================
# Redis cache for sessions and temporary data
REDIS_CACHE_URL_DEV=redis://localhost:6379
REDIS_CACHE_URL_PROD=redis://your-redis-host:6379

# Redis queue for background jobs and email processing
REDIS_QUEUE_URL_DEV=redis://localhost:6380
REDIS_QUEUE_URL_PROD=redis://your-redis-host:6380

# ============================================
# Google OAuth Configuration
# ============================================
# Get these from: https://console.developers.google.com/
# Project -> APIs & Services -> Credentials
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# OAuth callback URL (must match in Google Console)
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# Google API key for additional services
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_AUTH_API_KEY=your-google-api-key

# ============================================
# Cloudinary File Storage
# ============================================
# Get these from: https://cloudinary.com/console/
# Account -> Navigate to "Dashboard" -> Account Details
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# ============================================
# Zoom Video Integration
# ============================================
# Get these from: https://marketplace.zoom.us/
# Develop -> Build App -> JWT or Server-to-Server OAuth
ZOOM_ACCOUNT_ID=your-zoom-account-id
ZOOM_CLIENT_ID=your-zoom-client-id
ZOOM_CLIENT_SECRET=your-zoom-client-secret

# ============================================
# Email Service (Optional)
# ============================================
# Get from: https://resend.com/api-keys
# Used for appointment reminders and notifications
RESEND_API_KEY=your-resend-api-key

# ============================================
# Docker Configuration (for Docker development)
# ============================================
# These are automatically set in docker-compose.yaml
# DATABASE_URL_DEV=postgresql://postgres:postgres@medinfo-postgres-db:5432/medinfo
# REDIS_CACHE_URL_DEV=redis://medinfo-redis-cache:6379
# REDIS_QUEUE_URL_DEV=redis://medinfo-redis-queue:6379

# ============================================
# Development Notes
# ============================================
# 1. For local development, you can use provided defaults for most URLs
# 2. Generate strong secrets: openssl rand -base64 32
# 3. Never share or commit to version control
# 4. For production, use environment-specific .env files
# 5. Test Redis connections with: redis-cli ping
# 6. Test database connection with: psql $DATABASE_URL_DEV